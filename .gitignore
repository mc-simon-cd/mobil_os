# Orion OS - Git Ignore List (.gitignore)

# Ignore root output directory
out/

# Ignore Rust compilation artifacts
target/
**/target/

# Ignore C/C++ compiled binaries and libraries
*.o
*.a
*.so
*.elf
*.bin
*.img

# Editor and System files
.vscode/
.idea/
.cache/
.DS_Store
*~
*.swp
*.log
/tmp/

# Ignore compiled test binaries
tests/integration/test_launcher
tests/integration/test_power
tests/integration/test_statusbar
tests/unit/test_graphics_draw
tests/unit/test_i18n

