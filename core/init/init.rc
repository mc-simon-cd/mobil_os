# System Boot Configuration Manifest (init.rc)
# Orion OS v1.0.0-alpha — mcsimon

on boot
    mkdir /data 0755 root root
    mkdir /cache 0755 root root
    mkdir /tmp 0777 root root
    mkdir /run 0755 root root
    mkdir /system 0755 root root
    mkdir /system/bin 0755 root root
    mkdir /system/lib 0755 root root

# IPC broker — must start before any Binder client
service servicemanager /system/bin/servicemanager
    class core
    user root
    respawn

# Input pipeline — required before compositor and shell
service inputflinger /system/bin/inputflinger
    class core
    user root
    respawn

# Graphics compositor — register before shell clients
# Legacy PPM mode (default)
service surfaceflinger /system/bin/surfaceflinger
    class core
    user root
    respawn

# Power & network-facing daemons
service powermanager /system/bin/powermanager
    class main
    user root
    respawn

service apigateway /system/bin/apigateway
    class main
    user root
    respawn

# Shell UI
service statusbar /system/bin/statusbar
    class main
    user root
    respawn

# Application runtime (web control center) and shell
service apprunner /system/bin/apprunner
    class main
    user root
    args /system/apps/control_center
    respawn

# Shell home screen — interactive input loop with lock screen
service launcher /system/bin/launcher
    class main
    user root
    respawn
