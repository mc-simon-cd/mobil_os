#!/bin/sh
# Early system initialization script called by init (PID 1)

echo ""
echo "============================================="
echo "⚙️   Starting system initialization (/etc/init.d/rcS)"
echo "============================================="

# Mount filesystems listed in /etc/fstab
echo "⚙️   Mounting fstab virtual filesystem hooks..."
mount -a

# Ensure virtual directory nodes exist
mkdir -p /dev/pts
mkdir -p /dev/shm

# Mount devpts and tmpfs
mount -t devpts devpts /dev/pts
mount -t tmpfs tmpfs /dev/shm

# Check and build essential device nodes if devtmpfs is clean
if [ ! -c /dev/null ]; then
    echo "⚙️   Creating fallback character device nodes..."
    mknod -m 666 /dev/null c 1 3
    mknod -m 666 /dev/zero c 1 5
    mknod -m 660 /dev/console c 5 1
    mknod -m 666 /dev/tty c 5 0
fi

echo "✅ System initialization checks complete."
echo "============================================="
echo ""
